# WebMux environment variables
# Copy to .env and customize for your deployment.

# Root directory (defaults to webmux/ relative to backend/dist)
# WEBMUX_ROOT=/opt/webmux

# Override ports from app.yaml
# HTTP_PORT=8080
# HTTPS_PORT=8443

# JWT signing secret — MUST be set in production
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Node environment
# NODE_ENV=production
